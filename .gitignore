dist/
build/
*.egg-info/
*.egg

# ── macOS ────────────────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride

# ── IDE / Editor ─────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo

